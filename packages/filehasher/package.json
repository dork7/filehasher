{
  "name": "@dork7/filehasher",
  "version": "1.0.0",
  "description": "Password-protected file encryption (AES-256-GCM) with CLI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "filehasher": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dork7/filehasher.git",
    "directory": "packages/filehasher"
  },
  "bugs": {
    "url": "https://github.com/dork7/filehasher/issues"
  },
  "homepage": "https://github.com/dork7/filehasher/tree/main/packages/filehasher",
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc",
    "start": "node dist/cli.js",
    "hash": "node dist/cli.js hash",
    "env:hash": "node dist/cli.js env lock",
    "env:dehash": "node dist/cli.js env unlock"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "encrypt",
    "cli",
    "aes",
    "password"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.14.0",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
